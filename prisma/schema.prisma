generator client {
   provider = "prisma-client-js"
   binaryTargets = ["debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model cars {
  id           Int      @id @default(autoincrement())
  brand        String
  model        String
  year         Int
  price        Float
  mileage      Int
  fuel         String
  transmission String
  status       String   @default("available")
  images       String   @default("[]")
  description  String?
  created_at   DateTime @default(now())
}

model store_settings {
  id              Int     @id              // ← removido autoincrement, id sempre será 1
  phone           String
  email           String
  address         String
  hours_week      String
  hours_saturday  String
  hours_sunday    String
  instagram_url   String?
  facebook_url    String?
  hero_image_url  String?
  about_image_url String?
}